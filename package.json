{
  "name": "@telecom-scm/web",
  "version": "1.0.0",
  "private": true,
  "description": "电信供应链管理系统 - 前端统一工程",
  "packageManager": "pnpm@10.4.1",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "echo 'Please use start:admin, start:mall, start:mobile or start:weapp'",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,md,mdx,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,md,mdx,json}\"",
    "clean:all": "find . -name 'node_modules' -type d -prune -exec rm -rf '{}' +",
    "test": "pnpm -r test",
    "prepare": "husky install || echo 'husky install skipped: no .git directory'",
    "start:admin": "pnpm --filter @projects/admin dev",
    "start:mall": "pnpm --filter @projects/mall dev",
    "start:mobile": "pnpm --filter @projects/mobile dev",
    "start:weapp": "pnpm --filter @projects/weapp dev:weapp",
    "build:admin": "pnpm --filter=@projects/admin build",
    "build:mall": "pnpm --filter=@projects/mall build",
    "build:mobile": "pnpm --filter=@projects/mobile prebuild",
    "build:weapp": "pnpm --filter=@projects/weapp build:weapp",
    "test:admin": "npx cross-env ENV_TYPE=test pnpm start:admin",
    "test:mall": "npx cross-env ENV_TYPE=test pnpm start:mall",
    "test:mobile": "npx cross-env ENV_TYPE=test pnpm start:mobile",
    "test:weapp": "npx cross-env ENV_TYPE=test pnpm start:weapp",
    "type-check": "pnpm -r type-check",
    "lint:all": "pnpm -r lint",
    "publish:patch": "standard-version"
  },
  "devDependencies": {
    "@types/node": "^20.2.3",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/parser": "^5.57.0",
    "conventional-changelog-cli": "^4.1.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.3.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "husky": "^8.0.3",
    "lint-staged": "^13.2.0",
    "postcss-less": "^6.0.0",
    "prettier": "2.8.6",
    "standard-version": "^9.5.0",
    "stylelint": "^15.3.0",
    "stylelint-config-standard": "^31.0.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "axios": "^1.3.5",
    "classnames": "^2.3.2",
    "dayjs": "^1.11.13",
    "lodash": "^4.17.21",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tsconfig": "workspace:*"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --ext js,jsx,ts,tsx --quiet --fix --",
      "prettier --write"
    ],
    "*.{json,less,md,css,mdx}": [
      "prettier --write"
    ],
    "**/*.{css,less}": [
      "stylelint --fix"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "pnpm": {
    "overrides": {
      "react": "18.3.1",
      "react-dom": "18.3.1",
      "typescript": "^5.3.3",
      "@projects/mall>react": "^19.0.0",
      "@projects/mall>react-dom": "^19.0.0"
    }
  }
}
