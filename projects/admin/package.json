{
  "name": "@projects/admin",
  "version": "1.0.0",
  "private": true,
  "description": "电信供应链管理系统 - 管理后台",
  "repository": "git@github.com:ant-design/ant-design-pro.git",
  "scripts": {
    "analyze": "cross-env ANALYZE=1 max build",
    "build": "max build",
    "deploy": "npm run build && npm run gh-pages",
    "dev": "cross-env UMI_ENV=dev MOCK=none max dev",
    "gh-pages": "gh-pages -d dist",
    "type-check": "tsc --noEmit",
    "i18n-remove": "max i18n-remove --locale=zh-CN --write",
    "postinstall": "max setup",
    "jest": "jest",
    "lint": "eslint --ext .js,.jsx,.ts,.tsx src",
    "lint:fix": "eslint --ext .js,.jsx,.ts,.tsx src --fix",
    "openapi": "max openapi",
    "preview": "npm run build && max preview --port 8000",
    "record": "cross-env NODE_ENV=development UMI_ENV=test max record --scene=login",
    "serve": "umi-serve",
    "simple": "node scripts/simple.js",
    "start": "cross-env UMI_ENV=dev max dev",
    "start:dev": "cross-env UMI_ENV=dev MOCK=none max dev",
    "start:no-mock": "cross-env MOCK=none max dev",
    "start:pre": "cross-env UMI_ENV=pre MOCK=none max dev",
    "start:test": "cross-env UMI_ENV=test MOCK=none max dev",
    "test": "jest",
    "test:coverage": "npm run jest -- --coverage",
    "test:update": "npm run jest -- -u",
    "tsc": "tsc --noEmit"
  },
  "browserslist": [
    "defaults"
  ],
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "@ant-design/plots": "^2.6.0",
    "@ant-design/pro-components": "3.1.2-0",
    "@antv/l7": "^2.22.7",
    "@antv/l7-react": "^2.4.3",
    "@apps/config": "workspace:^1.0.0",
    "@apps/constants": "workspace:^1.0.0",
    "@apps/types": "workspace:^1.0.0",
    "@apps/utils": "workspace:^1.0.0",
    "@rc-component/util": "^1.9.0",
    "antd": "^6.2.2",
    "antd-style": "^4.1.0",
    "classnames": "^2.3.2",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.13",
    "numeral": "^2.0.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.0.0",
    "tsconfig": "workspace:^1.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.3.0",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.2.3",
    "@types/numeral": "^2.0.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/react-helmet": "^6.1.11",
    "@umijs/lint": "^4.6.13",
    "@umijs/max": "^4.6.25",
    "cross-env": "^7.0.3",
    "eslint": "^8.3.0",
    "express": "^5.2.0",
    "gh-pages": "^6.1.1",
    "jest": "^30.0.4",
    "jest-environment-jsdom": "^30.0.5",
    "lint-staged": "^13.2.0",
    "mockjs": "^1.1.0",
    "tailwindcss": "^3.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "swagger-ui-dist": "^5.11.0",
    "umi-presets-pro": "^2.0.3",
    "umi-serve": "^1.9.11"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "create-umi": {
    "ignoreScript": [
      "docker*",
      "functions*",
      "site",
      "generateMock"
    ],
    "ignoreDependencies": [
      "netlify*",
      "serverless"
    ],
    "ignore": [
      ".dockerignore",
      ".git",
      ".github",
      ".gitpod.yml",
      "CODE_OF_CONDUCT.md",
      "Dockerfile",
      "Dockerfile.*",
      "lambda",
      "LICENSE",
      "netlify.toml",
      "README.*.md",
      "azure-pipelines.yml",
      "docker",
      "CNAME",
      "create-umi"
    ]
  }
}
