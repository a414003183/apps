{
  "extends": "tsconfig/base.json",
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["ES2017", "DOM"],
    "module": "ESNext",
    "moduleResolution": "node",
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "types": ["@tarojs/taro", "@types/react", "@types/node", "@types/webpack-env"],
    "allowJs": true,
    "checkJs": false,
    "noEmit": true
  },
  "include": ["./src/**/*", "./config/**/*"],
  "exclude": ["node_modules", "dist", "build"]
}
